# =============================================================================
# Django Core Settings
# =============================================================================
DEBUG=False
SECRET_KEY=<generate-a-strong-random-key>
ALLOWED_HOSTS=your-app.vercel.app

# =============================================================================
# Database Configuration (REQUIRED for Vercel — use Vercel Postgres or Neon)
# =============================================================================
DATABASE_URL=postgres://user:password@host:5432/dbname

# =============================================================================
# External News APIs
# =============================================================================
WORLD_NEWS_API_KEY=<your-worldnewsapi-key>
NEWS_API_KEY=<your-newsapi-org-key>
FINNHUB_API_KEY=<your-finnhub-api-key>

# =============================================================================
# Email Configuration
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST_USER=<your-email@gmail.com>
EMAIL_HOST_PASSWORD=<your-gmail-app-password>
DEFAULT_FROM_EMAIL=NewsHub <noreply@yourdomain.com>

# =============================================================================
# CORS (React Frontend Origin)
# =============================================================================
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# =============================================================================
# Frontend (React/Vite)
# =============================================================================
VITE_API_BASE_URL=https://your-app.vercel.app/api/
